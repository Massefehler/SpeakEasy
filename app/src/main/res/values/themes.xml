<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SpeakEasy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <!-- Edge-to-edge: ab Android 15 (API 35) wird die App-Oberfläche unter
             Status-/Navigationsleiste gemalt; den Hintergrund machen wir transparent
             und kümmern uns in MainActivity um die System-Insets. -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="ShapeAppearance.SpeakEasy.HeaderBottom" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">32dp</item>
        <item name="cornerSizeBottomRight">32dp</item>
    </style>

    <style name="SpeakEasy.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">20dp</item>
    </style>

    <style name="SpeakEasy.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">64dp</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="cornerRadius">32dp</item>
    </style>

    <style name="SpeakEasy.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">28dp</item>
    </style>
</resources>
